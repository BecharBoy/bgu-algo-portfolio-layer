# ── Interactive Brokers ───────────────────────────────────────────
IB_HOST=127.0.0.1
IB_PORT=7497
IB_CLIENT_ID=1

# ── PostgreSQL ────────────────────────────────────────────────────
DB_CONNECTION_STRING=postgresql://user:password@host:5432/dbname

# ── Gemini ────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# ── Runtime ───────────────────────────────────────────────────────
TRADE_MODE=paper           # paper | live
